# Flask
FLASK_SECRET=secret123

# Blockchain
CHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CHAIN_PRIVATE_KEY=0xabc123...
CHAIN_CONTRACT_ADDRESS=0xcontract
# Path to Hardhat artifact containing the ABI
CHAIN_ABI_PATH=chain/artifacts/contracts/PharmaLedger.sol/PharmaLedger.json
